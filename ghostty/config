# Theme and Appearance
theme = Iceberg Dark
bold-color = bright

# Window
background-opacity = 0.85
background-blur = 5
title = " "
window-subtitle = false
window-height = 45
window-width = 170
window-padding-x = 4
window-padding-y = 0,10

# Notifications
app-notifications = false
bell-features = no-attention,no-title
desktop-notifications = true

# macOS
macos-window-shadow = false
macos-titlebar-proxy-icon = hidden
macos-non-native-fullscreen = true
macos-option-as-alt = left
macos-titlebar-style = tabs

# Shell Integration
mouse-hide-while-typing = false
copy-on-select = true
link-url = true

# Cursor
cursor-style = block
cursor-style-blink = false

# SSH
shell-integration-features = ssh-terminfo,ssh-env,no-cursor

# Font
font-size = 26
font-family = RictyDiscord Nerd Font
font-style = Bold
font-style-italic = Bold Oblique
font-style-bold-italic = Bold Oblique
font-thicken = true
font-thicken-strength = 255
font-feature = -calt,-liga,-dlig

# Behavior
quit-after-last-window-closed = true

# Clipboard
copy-on-select = clipboard
clipboard-read = allow
clipboard-write = allow
clipboard-trim-trailing-spaces = true

# Key Bindings
keybind = all:cmd+w=ignore
keybind = all:cmd+q=ignore
## For new line without executing especially for Claude Code
keybind = all:shift+enter=text:\n
## Do not open config file with cmd+,
keybind = all:cmd+,=ignore
## Disable toggle_fullscreen
keybind = all:cmd+enter=ignore
